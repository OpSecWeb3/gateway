# Shared Infra — production .env
#
# In prod this file is generated on each deploy by .github/workflows/deploy.yml
# from SSM parameters under /shared/production/*. For reference only.

# Postgres — creds for the shared postgres server. Must match the user/password
# baked into consumers' DATABASE_URLs (e.g. /sentinel/production/DATABASE_URL).
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Redis — password used to start redis with --requirepass. Consumers include
# it in their REDIS_URL (redis://:${REDIS_PASSWORD}@redis:6379).
REDIS_PASSWORD=
